{
  "version": 1,
  "description": "Tournament rule data: legendaries blocked from battle teams, banned moves, level caps, and per-game data routing.",
  "levelCaps": [55, 60],
  "legendaries": [
    "Articuno", "Zapdos", "Moltres", "Mewtwo", "Mew",
    "Raikou", "Entei", "Suicune", "Lugia", "Ho-oh", "Celebi",
    "Regirock", "Regice", "Registeel", "Latias", "Latios",
    "Kyogre", "Groudon", "Rayquaza", "Jirachi", "Deoxys-normal"
  ],
  "bannedMoves": {
    "accuracyReducers": {
      "rule": "No accuracy-reducing moves (status moves that lower the opponent's accuracy).",
      "moves": [
        "Sand Attack",
        "Smokescreen",
        "Flash",
        "Kinesis"
      ]
    },
    "ohko": {
      "rule": "No one-hit knockout moves. Perish Song is allowed because it's a delayed condition, not an instant KO.",
      "moves": [
        "Guillotine",
        "Horn Drill",
        "Fissure",
        "Sheer Cold"
      ]
    },
    "nonDamagingRecovery": {
      "rule": "No HP-recovery moves unless the move also causes damage.",
      "moves": [
        "Recover",
        "Rest",
        "Soft Boiled",
        "Synthesis",
        "Milk Drink",
        "Moonlight",
        "Morning Sun",
        "Swallow",
        "Wish",
        "Ingrain"
      ]
    }
  },
  "warnMoves": {
    "damagingAccuracyReducers": {
      "rule": "These moves deal damage but also lower the opponent's accuracy. Confirm with your group whether they count as banned.",
      "moves": [
        "Mud Slap",
        "Octazooka",
        "Muddy Water"
      ]
    },
    "drainAndPainSplit": {
      "rule": "These moves recover HP via damage — generally allowed under the 'unless it causes damage' carve-out, but flagged for awareness.",
      "moves": [
        "Absorb",
        "Mega Drain",
        "Giga Drain",
        "Leech Life",
        "Leech Seed",
        "Dream Eater",
        "Pain Split"
      ]
    }
  },
  "tradeEvolutions": {
    "rule": "Allowed via partner trade-back during the 18-hour run.",
